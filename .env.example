# Renomeie este arquivo para .env e insira sua chave de API
# A API da Groq é super rápida e gratuita: https://console.groq.com/keys
GROQ_API_KEY="coloque_sua_chave_groq_aqui"

# Ou, se preferir usar a OpenAI (paga):
# OPENAI_API_KEY="sk-..."

# Configuração para sincronização com o AnkiWeb (opcional)
ANKIWEB_USER="seu_email@exemplo.com"
ANKIWEB_PASSWORD="sua_senha_do_ankiweb"

# OpenRouter (opcional) — modelos grátis usados pelo revisor de flashcards.
# Crie uma chave em https://openrouter.ai/keys. Se ausente, o revisor usa o Groq.
# OPENROUTER_API_KEY="sk-or-v1-..."
